{
  "name": "fju-smart-hub",
  "version": "1.0.0",
  "description": "FJU Smart Hub - 輔仁大學全方位校園管理與資源調度系統",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:sandbox": "wrangler pages dev dist --ip 0.0.0.0 --port 3000",
    "dev:d1": "wrangler pages dev dist --d1=fju-smart-hub-production --local --ip 0.0.0.0 --port 3000",
    "build": "vite build",
    "preview": "wrangler pages dev dist",
    "deploy": "npm run build && wrangler pages deploy dist --project-name fju-smart-hub",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "clean-port": "fuser -k 3000/tcp 2>/dev/null || true",
    "db:migrate:local": "wrangler d1 migrations apply fju-smart-hub-production --local",
    "db:migrate:prod": "wrangler d1 migrations apply fju-smart-hub-production",
    "db:seed": "wrangler d1 execute fju-smart-hub-production --local --file=./seed.sql",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:local && npm run db:seed"
  },
  "dependencies": {
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250705.0",
    "@hono/vite-cloudflare-pages": "^0.4.2",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "wrangler": "^3.78.0"
  }
}
